# Example environment for backend
# Copy to .env and fill with your real values

# Appwrite
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key
ORDERS_COLLECTION_ID=your_orders_collection_id

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_CALLBACK_URL=https://01c76832d992.ngrok-free.app/api/paystack-callback

# Frontend base url (for callback redirects)
FRONTEND_BASE_URL=https://your-ngrok-id.ngrok.io

# Zoho - you can store a refresh token in Appwrite or set here
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:3000/zoho/callback
# Optional if you manage tokens outside Appwrite
ZOHO_REFRESH_TOKEN=your_refresh_token

# Zoho list keys
# MAIN_LIST_KEY = list to add contacts when they click Buy (initial)
MAIN_LIST_KEY=your_main_list_key
# PAID_BEFORE_LIST_KEY = list to add buyers who purchased BEFORE the offer deadline
PAID_BEFORE_LIST_KEY=your_paid_before_list_key
# PAID_AFTER_LIST_KEY = list to add buyers who purchased AFTER the offer deadline
PAID_AFTER_LIST_KEY=your_paid_after_list_key
# Fallback single paid list (optional)
PAID_LIST_KEY=your_paid_list_key
# UNCONFIRMED_PAYMENT_LIST_KEY = list to add users who clicked "Confirm Payment" on crypto/other payment methods
UNCONFIRMED_PAYMENT_LIST_KEY=your_unconfirmed_payment_list_key

# Optional: set a minWatchMinutes that the frontend will use (defaults to 0.5 minutes)
# This is a client-side setting but keep here for reference
# MIN_WATCH_MINUTES=0.5

 
